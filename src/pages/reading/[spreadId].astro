---
import Layout from '../../layouts/Layout.astro';
import ReadingWizard from '../../components/ReadingWizard';
import { detectLanguage, createTranslator } from '../../utils/i18nServer';
import { loadSpreads } from '../../utils/loadData';

export const prerender = false;

const lang = detectLanguage(Astro.request);
const t = createTranslator(lang, 'common');
const spreads = loadSpreads(lang);

const { spreadId } = Astro.params;
const spread = spreads.find(s => s.id === spreadId);

if (!spread) {
  return Astro.redirect('/');
}
---

<Layout
  title={`${spread.name} Reading`}
  description={`Get your ${spread.name} tarot reading. ${spread.description}`}
  noindex={true}
>
  <div class="container mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold mb-2 text-violet-deep">
        {spread.name}
      </h1>
    </div>

    <!-- 3-step Reading Wizard -->
    <ReadingWizard
      client:load
      cardCount={spread.cardCount}
      spreadId={spreadId}
      spread={spread}
    />
  </div>
</Layout>
