---
import Layout from '../../layouts/Layout.astro';
import { detectLanguage, createTranslator } from '../../utils/i18nServer';
import { withLang } from '../../utils/linkHelper';
import cardsData from '../../data/cards.json';

// Detect language
const lang = detectLanguage(Astro.request);

// Create translator
const t = createTranslator(lang, 'common');

// Organize cards by type
const majorArcana = cardsData.filter(c => c.arcana === 'major');
const wands = cardsData.filter(c => c.suit === 'wands');
const cups = cardsData.filter(c => c.suit === 'cups');
const swords = cardsData.filter(c => c.suit === 'swords');
const pentacles = cardsData.filter(c => c.suit === 'pentacles');
---

<Layout
  title={t('cardsPage.title')}
  description={t('cardsPage.description')}
>
  <div class="container mx-auto px-4 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-violet-deep">
        {t('cardsPage.header')}
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        {t('cardsPage.subtitle')}
      </p>
    </div>

    <!-- Search Bar -->
    <div class="max-w-2xl mx-auto mb-8">
      <div class="relative">
        <input
          id="card-search"
          type="search"
          placeholder={t('cardsPage.searchPlaceholder') as string}
          class="w-full px-5 py-3 pl-12 rounded-full border-2 border-violet-200 focus:border-violet-medium focus:outline-none text-gray-800 shadow-sm"
          autocomplete="off"
        />
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-violet-400 pointer-events-none">🔍</span>
      </div>
      <div id="search-no-results" class="hidden text-center text-gray-500 mt-4 text-sm">
        {t('cardsPage.searchNoResults')}
      </div>
    </div>

    <!-- Filter Tabs -->
    <div class="flex flex-wrap justify-center gap-2 mb-8">
      <button data-filter="all" class="filter-btn active px-6 py-2 rounded-full bg-violet-deep text-white hover:bg-violet-medium transition-colors">
        {t('cardsPage.filters.all')}
      </button>
      <button data-filter="major" class="filter-btn px-6 py-2 rounded-full bg-white border-2 border-violet-medium text-violet-medium hover:bg-violet-medium hover:text-white transition-all">
        {t('cardsPage.filters.major')}
      </button>
      <button data-filter="wands" class="filter-btn px-6 py-2 rounded-full bg-white border-2 border-violet-medium text-violet-medium hover:bg-violet-medium hover:text-white transition-all">
        {t('cardsPage.filters.wands')}
      </button>
      <button data-filter="cups" class="filter-btn px-6 py-2 rounded-full bg-white border-2 border-violet-medium text-violet-medium hover:bg-violet-medium hover:text-white transition-all">
        {t('cardsPage.filters.cups')}
      </button>
      <button data-filter="swords" class="filter-btn px-6 py-2 rounded-full bg-white border-2 border-violet-medium text-violet-medium hover:bg-violet-medium hover:text-white transition-all">
        {t('cardsPage.filters.swords')}
      </button>
      <button data-filter="pentacles" class="filter-btn px-6 py-2 rounded-full bg-white border-2 border-violet-medium text-violet-medium hover:bg-violet-medium hover:text-white transition-all">
        {t('cardsPage.filters.pentacles')}
      </button>
    </div>

    <!-- Major Arcana Section -->
    <section id="section-major" class="card-section mb-16">
      <h2 class="text-3xl font-heading text-violet-deep mb-6">
        {t('cardsPage.sections.majorArcana')}
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        {majorArcana.map((card) => (
          <a
            href={withLang(`/cards/${card.slug}`, lang)}
            class="card-item bg-white rounded-lg shadow-md hover:shadow-xl transition-all card-hover p-4"
            data-type="major"
            data-slug={card.slug}
          >
            <div class="aspect-[2/3] rounded-lg overflow-hidden mb-3">
              <img
                src={card.image}
                alt={card.name}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="font-heading text-sm text-violet-deep text-center mb-1">
              {card.name}
            </h3>
            <p class="text-xs text-gray-600 text-center line-clamp-2">
              {card.keywords.join(', ')}
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- Wands Section -->
    <section id="section-wands" class="card-section mb-16">
      <h2 class="text-3xl font-heading text-violet-deep mb-6">
        {t('cardsPage.sections.suitOfWands')}
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 gap-4">
        {wands.map((card) => (
          <a
            href={withLang(`/cards/${card.slug}`, lang)}
            class="card-item bg-white rounded-lg shadow-md hover:shadow-xl transition-all card-hover p-4"
            data-type="wands"
            data-slug={card.slug}
          >
            <div class="aspect-[2/3] rounded-lg overflow-hidden mb-3">
              <img
                src={card.image}
                alt={card.name}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="font-heading text-sm text-violet-deep text-center">
              {card.name}
            </h3>
          </a>
        ))}
      </div>
    </section>

    <!-- Cups Section -->
    <section id="section-cups" class="card-section mb-16">
      <h2 class="text-3xl font-heading text-violet-deep mb-6">
        {t('cardsPage.sections.suitOfCups')}
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 gap-4">
        {cups.map((card) => (
          <a
            href={withLang(`/cards/${card.slug}`, lang)}
            class="card-item bg-white rounded-lg shadow-md hover:shadow-xl transition-all card-hover p-4"
            data-type="cups"
            data-slug={card.slug}
          >
            <div class="aspect-[2/3] rounded-lg overflow-hidden mb-3">
              <img
                src={card.image}
                alt={card.name}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="font-heading text-sm text-violet-deep text-center">
              {card.name}
            </h3>
          </a>
        ))}
      </div>
    </section>

    <!-- Swords Section -->
    <section id="section-swords" class="card-section mb-16">
      <h2 class="text-3xl font-heading text-violet-deep mb-6">
        {t('cardsPage.sections.suitOfSwords')}
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 gap-4">
        {swords.map((card) => (
          <a
            href={withLang(`/cards/${card.slug}`, lang)}
            class="card-item bg-white rounded-lg shadow-md hover:shadow-xl transition-all card-hover p-4"
            data-type="swords"
            data-slug={card.slug}
          >
            <div class="aspect-[2/3] rounded-lg overflow-hidden mb-3">
              <img
                src={card.image}
                alt={card.name}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="font-heading text-sm text-violet-deep text-center">
              {card.name}
            </h3>
          </a>
        ))}
      </div>
    </section>

    <!-- Pentacles Section -->
    <section id="section-pentacles" class="card-section mb-16">
      <h2 class="text-3xl font-heading text-violet-deep mb-6">
        {t('cardsPage.sections.suitOfPentacles')}
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 gap-4">
        {pentacles.map((card) => (
          <a
            href={withLang(`/cards/${card.slug}`, lang)}
            class="card-item bg-white rounded-lg shadow-md hover:shadow-xl transition-all card-hover p-4"
            data-type="pentacles"
            data-slug={card.slug}
          >
            <div class="aspect-[2/3] rounded-lg overflow-hidden mb-3">
              <img
                src={card.image}
                alt={card.name}
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="font-heading text-sm text-violet-deep text-center">
              {card.name}
            </h3>
          </a>
        ))}
      </div>
    </section>

    <!-- Footer Note -->
    <div class="text-center mt-12 text-gray-500 text-sm">
      <p>{t('cardsPage.footerNote')}</p>
      <p class="mt-2">
        <a href={withLang('/', lang)} class="text-violet-medium hover:text-gold-soft">{t('cardsPage.backToReadings')}</a>
      </p>
    </div>
  </div>

  <!-- Inject card data for search (define:vars, no imports allowed here) -->
  <script define:vars={{ cardsForSearch: cardsData.map(c => ({ slug: c.slug, name: c.name, suit: c.suit ?? 'major', keywords: c.keywords.join(' ') })) }}>
    window.__tarotCards = cardsForSearch;
  </script>

  <!-- Filter + Fuse.js Search (module script — imports allowed) -->
  <script>
    import Fuse from 'fuse.js';

    // ── Filter ───────────────────────────────────────────────────────────────
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cardSections = document.querySelectorAll('.card-section');
    const cardItems = document.querySelectorAll('.card-item');
    let activeFilter = 'all';

    function applyFilter(filter) {
      activeFilter = filter;
      filterBtns.forEach(b => {
        const isActive = b.dataset.filter === filter;
        b.classList.toggle('bg-violet-deep', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-white', !isActive);
        b.classList.toggle('border-2', !isActive);
        b.classList.toggle('border-violet-medium', !isActive);
        b.classList.toggle('text-violet-medium', !isActive);
      });

      const searchActive = (document.getElementById('card-search') as HTMLInputElement).value.trim() !== '';
      if (searchActive) return;

      if (filter === 'all') {
        cardSections.forEach(s => (s as HTMLElement).style.display = 'block');
        cardItems.forEach(i => (i as HTMLElement).style.display = 'block');
      } else {
        cardSections.forEach(s => {
          (s as HTMLElement).style.display = s.id.replace('section-', '') === filter ? 'block' : 'none';
        });
        cardItems.forEach(i => {
          (i as HTMLElement).style.display = (i as HTMLElement).dataset.type === filter ? 'block' : 'none';
        });
      }
    }

    filterBtns.forEach(btn => btn.addEventListener('click', () => applyFilter((btn as HTMLElement).dataset.filter!)));

    // ── Fuse.js Search ────────────────────────────────────────────────────────
    const cards = (window as any).__tarotCards as { slug: string; name: string; suit: string; keywords: string }[];
    const fuse = new Fuse(cards, {
      keys: ['name', 'keywords'],
      threshold: 0.35,
      minMatchCharLength: 2,
    });

    const searchInput = document.getElementById('card-search') as HTMLInputElement;
    const noResults = document.getElementById('search-no-results')!;

    searchInput.addEventListener('input', () => {
      const query = searchInput.value.trim();

      if (!query) {
        noResults.classList.add('hidden');
        applyFilter(activeFilter);
        return;
      }

      cardSections.forEach(s => (s as HTMLElement).style.display = 'none');
      cardItems.forEach(i => (i as HTMLElement).style.display = 'none');

      const matched = new Set(fuse.search(query).map(r => r.item.slug));

      cardItems.forEach(item => {
        const el = item as HTMLElement;
        if (matched.has(el.dataset.slug!)) {
          el.style.display = 'block';
          const section = document.getElementById(`section-${el.dataset.type === 'major' ? 'major' : el.dataset.type}`);
          if (section) section.style.display = 'block';
        }
      });

      noResults.classList.toggle('hidden', matched.size > 0);
    });
  </script>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
