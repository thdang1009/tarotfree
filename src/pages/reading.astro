---
import Layout from '../layouts/Layout.astro';
import ReadingWizard from '../components/ReadingWizard';
import spreads from '../data/spreads.json';

const spreadId = Astro.url.searchParams.get('spread') || '1-card';
const spread = spreads.find(s => s.id === spreadId);

if (!spread) {
  return Astro.redirect('/');
}
---

<Layout
  title={`${spread.name} Reading`}
  description={`Get your ${spread.name} tarot reading. ${spread.description}`}
  noindex={true}
>
  <div class="container mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold mb-2 text-violet-deep">
        {spread.name}
      </h1>
    </div>

    <ReadingWizard
      client:load
      cardCount={spread.cardCount}
      spreadId={spreadId}
      spread={spread}
    />
  </div>
</Layout>
